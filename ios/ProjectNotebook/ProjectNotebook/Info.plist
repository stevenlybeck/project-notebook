<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Notebook</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.projectnotebook.pair</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>projectnotebook</string>
			</array>
		</dict>
	</array>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- IMPORTANT: do NOT add NSAllowsLocalNetworking here. On iOS 10+
		     its mere presence makes the system IGNORE NSAllowsArbitraryLoads
		     (Apple's documented "child keys disable the parent" rule), and
		     NSAllowsLocalNetworking's allowlist only covers RFC1918 ranges
		     (10/8, 172.16/12, 192.168/16) — it does not cover overlay IPs
		     like Tailscale's CGNAT (100.64/10), so URLSession will refuse
		     plaintext requests with -1022. We rely on NSAllowsArbitraryLoads
		     alone; trust comes from the bearer device token + user-controlled
		     pairing, same trusted-LAN model we already documented. -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Project Notebook needs local network access to connect to the hub on your Mac.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_notebook._tcp</string>
		<string>_preflight_check._tcp</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIStatusBarStyle</key>
	<string></string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
